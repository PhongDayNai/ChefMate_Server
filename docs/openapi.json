    },
    "/api/recipes/trending-v2": {
      "get": {
        "tags": [
          "Recipes"
        ],
        "summary": "Trending v2 (pagination for infinite scroll)",
        "description": "Feed thịnh hành có phân trang cho infinite scroll.\nPayload recipe trong `data.items` tương thích v1 (top-trending), chỉ bổ sung `pagination` và `period`.",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Optional. Nếu có, trả thêm trạng thái isLiked"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Trang hiện tại"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 50
            },
            "description": "Số item mỗi trang"
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "7d",
                "30d",
                "90d"
              ],
              "default": "all"
            },
            "description": "Khoảng thời gian tính trend"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrendingV2Response"
                }
              }
            }
          }
        },
        "operationId": "getTrendingV2"
      }
    },
