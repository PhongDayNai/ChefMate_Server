        ],
        "summary": "Chat with AI",
        "description": "Gửi message tới AI. Nếu không truyền `chatSessionId`, server tự tạo session + auto-title + intro Bepes rồi mới xử lý message.\nKhi AI upstream bận/lỗi sẽ trả `503` với `code=AI_SERVER_BUSY`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatMessageRequest"
              },
              "examples": {
