{
  "openapi": "3.0.3",
  "info": {
    "title": "ChefMate Server API",
    "version": "2.0.0",
    "description": "Tài liệu đầy đủ API ChefMate (legacy + mới), gồm flow sử dụng, phân trang, AI chat, pantry, diet notes và xử lý lỗi.\n\n## Quickstart Flow\n1) Lấy diet notes + pantry\n2) Lấy recommendations từ pantry\n3) Tạo session (hoặc để messages auto-create)\n4) Chọn active recipe\n5) Chat với AI\n6) Load lại sessions + history\n"
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Production"
    },
    {
      "url": "http://127.0.0.1:8000",
      "description": "Local Docker"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Nhóm API tài khoản người dùng (legacy)."
    },
    {
      "name": "Recipes",
      "description": "Nhóm API công thức, tìm kiếm, thịnh hành v1/v2."
    },
    {
      "name": "Interactions",
      "description": "Like, comment, tăng view công thức."
    },
    {
      "name": "Pantry",
      "description": "Quản lý tủ lạnh theo từng user."
    },
    {
      "name": "UserDietNotes",
      "description": "Ghi chú ăn uống: dị ứng/hạn chế/sở thích/sức khỏe."
    },
    {
      "name": "AIChat",
      "description": "Session chat nấu ăn, chọn món, gửi message và history."
    },
    {
      "name": "FlowGuide",
      "description": "Mô tả flow tích hợp gợi ý cho client."
    }
  ],
  "paths": {
    "/api/users/all": {
