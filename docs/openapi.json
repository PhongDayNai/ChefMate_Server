    "/api/recipes/create": {
      "post": {
        "tags": [
          "Recipes"
        ],
        "summary": "Create recipe (multipart)",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "image",
                  "recipeName",
                  "cookingTime",
                  "ration",
                  "ingredients",
                  "cookingSteps",
                  "userId"
                ],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "recipeName": {
                    "type": "string"
                  },
                  "cookingTime": {
                    "type": "string"
                  },
                  "ration": {
                    "type": "integer"
                  },
                  "ingredients": {
                    "type": "string",
                    "description": "JSON string array"
                  },
                  "cookingSteps": {
                    "type": "string",
                    "description": "JSON string array"
                  },
                  "tags": {
                    "type": "string",
                    "description": "JSON string array"
                  },
                  "userId": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
