    "/api/ai-chat/sessions": {
      "post": {
        "tags": [
          "AIChat"
        ],
        "summary": "Create chat session",
        "description": "Tạo session chat. Nếu không truyền `title`, server tự đặt tên bằng AI từ `firstMessage`.\nSession mới luôn được chèn message giới thiệu của agent **Bepes** ngay đầu lịch sử.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              },
              "examples": {
                "AutoTitleByFirstMessage": {
                  "summary": "Không truyền title, để server đặt tên tự động bằng AI",
                  "value": {
                    "userId": 4,
                    "firstMessage": "Tôi muốn nấu món bò nhanh cho bữa tối",
                    "model": "gemma3:4b"
                  }
                },
                "CustomTitle": {
                  "summary": "Truyền title thủ công",
                  "value": {
                    "userId": 4,
                    "title": "Bữa tối healthy",
                    "activeRecipeId": null
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "links": {
              "GetCreatedSessionHistory": {
                "operationId": "getChatSessionHistory",
                "parameters": {
                  "sessionId": "$response.body#/data/chatSessionId",
                  "userId": "$response.body#/data/userId"
                },
                "description": "Lấy ngay lịch sử session vừa tạo (sẽ có intro message Bepes)."
              },
              "SendFirstMessageToCreatedSession": {
                "operationId": "sendChatMessage",
                "requestBody": {
                  "userId": "$response.body#/data/userId",
                  "chatSessionId": "$response.body#/data/chatSessionId",
                  "message": "Xin chào Bepes, bắt đầu nấu món cho tôi nhé",
                  "stream": false
                },
                "description": "Gửi message đầu tiên cho session vừa tạo."
              }
            }
          }
        },
        "operationId": "createChatSession"
      },
      "get": {
        "tags": [
          "AIChat"
        ],
        "summary": "List chat sessions by user (pagination)",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "operationId": "listChatSessions"
      }
    },
