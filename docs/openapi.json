  "x-flow-guide": {
    "recommendedClientFlow": [
      "1) GET /api/user-diet-notes?userId=...",
      "2) GET /api/pantry?userId=...",
      "3) POST /api/ai-chat/recommendations-from-pantry",
      "4) POST /api/ai-chat/sessions (optional, hoặc để messages auto-create)",
      "5) PATCH /api/ai-chat/sessions/active-recipe",
      "6) POST /api/ai-chat/messages",
      "7) GET /api/ai-chat/sessions?userId=...&page=...&limit=...",
      "8) GET /api/ai-chat/sessions/{id}?userId=..."
    ],
    "errorHandling": {
      "AI_SERVER_BUSY_503": "Hiển thị fallback + retry sau 3-5s, tối đa 2-3 lần",
      "404_ChatSessionNotFound": "Kiểm tra đúng cặp sessionId + userId",
      "emptyRecommendations": "Kiểm tra pantry trống hoặc đang bị filter bởi allergy/restriction"
    },
    "compatibility": {
      "legacyTopTrending": "POST /api/recipes/top-trending giữ nguyên contract cũ",
      "newTrendingV2": "GET /api/recipes/trending-v2 dùng cho infinite scroll"
    },
    "flows": {
      "SessionBasedChat": {
        "goal": "Chat theo phiên, có khả năng đổi món trong lúc nấu",
        "steps": [
          "POST /api/ai-chat/sessions",
          "PATCH /api/ai-chat/sessions/active-recipe",
          "POST /api/ai-chat/messages",
          "GET /api/ai-chat/sessions/{id}?userId=..."
        ]
      },
      "AutoSessionChat": {
        "goal": "Cho phép gửi message ngay khi chưa có session",
        "steps": [
          "POST /api/ai-chat/messages (without chatSessionId)",
          "Server tự tạo session + auto-title + intro Bepes",
          "Client đọc sessionId trong response để dùng cho các lượt sau"
        ]
      },
      "TrendingInfiniteScrollV2": {
        "goal": "Cuộn danh sách thịnh hành không giới hạn",
        "steps": [
          "GET /api/recipes/trending-v2?page=1&limit=20",
          "Append data.items vào list",
          "Nếu pagination.hasMore=true thì tăng page và gọi tiếp"
        ]
      }
    },
    "retryPolicy": {
      "AI_SERVER_BUSY": {
        "httpStatus": 503,
        "retryAfterSeconds": "3-5",
        "maxRetries": 3,
        "strategy": "exponential backoff nhẹ (3s, 5s, 8s)"
      }
    }
  },
  "externalDocs": {
