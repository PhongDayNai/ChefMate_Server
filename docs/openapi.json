                  "summary": "Chat trong session đã có",
                  "value": {
                    "userId": 4,
                    "chatSessionId": 26,
                    "message": "Hướng dẫn bước 1 thật ngắn",
                    "model": "gemma3:4b",
                    "stream": true
                  }
                },
                "AutoCreateSession": {
                  "summary": "Không có chatSessionId => server auto tạo session",
                  "value": {
                    "userId": 4,
                    "message": "Tôi muốn ăn món gà ít dầu mỡ tối nay",
                    "model": "gemma3:4b",
                    "stream": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "503": {
            "$ref": "#/components/responses/AIServerBusy"
          }
        },
        "operationId": "sendChatMessage"
      }
    }
