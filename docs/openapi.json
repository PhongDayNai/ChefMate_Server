    "/api/recipes/top-trending": {
      "post": {
        "tags": [
          "Recipes"
        ],
        "summary": "Top trending (legacy, fixed 30)",
        "description": "Legacy contract. Trả array recipe đầy đủ (full payload).",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
