# Server
PORT=8080

# MySQL
DB_HOST=mysql
DB_PORT=3306
DB_USER=chefmate
DB_PASSWORD=__CHANGE_ME_DB_PASSWORD__
DB_NAME=chefmate_db
DB_CONNECTION_LIMIT=10

# Docker Compose MySQL (for local container)
MYSQL_ROOT_PASSWORD=__CHANGE_ME_MYSQL_ROOT_PASSWORD__
MYSQL_DATABASE=chefmate_db
MYSQL_USER=chefmate
MYSQL_PASSWORD=__CHANGE_ME_MYSQL_PASSWORD__

# AI Chat
AI_CHAT_API_URL=https://your-ai-api-url.com
AI_CHAT_MODEL=gemma3:4b
AI_CHAT_TIMEOUT_MS=20000
AI_CHAT_SYSTEM_PROMPT=
AI_CHAT_TITLE_MODEL=gemma3:4b

# Legacy chat API key (port 8000)
CHAT_API_KEY=__CHANGE_ME_CHAT_API_KEY__

# JWT server (port 13081)
JWT_ACCESS_SECRET=__CHANGE_ME_JWT_ACCESS_SECRET__
JWT_REFRESH_SECRET=__CHANGE_ME_JWT_REFRESH_SECRET__
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
